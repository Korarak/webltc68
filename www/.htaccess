RewriteEngine On

# Rewrite /about-us to /app-webpage/page.php?slug=about-us
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9-]+)/?$ /app-webpage/page.php?slug=$1 [L,QSA]

# หรือถ้าต้องการให้อยู่ในโฟลเดอร์ pages/
RewriteRule ^pages/([a-zA-Z0-9-]+)/?$ /app-webpage/page.php?slug=$1 [L,QSA]

# ป้องกัน directory listing
Options -Indexes

# Redirect 404 errors
ErrorDocument 404 /404.php

# ป้องกันการเข้าถึงไฟล์敏感
<Files ~ "\.(env|log|sql)$">
    Deny from all
</Files>